---
import { ClientRouter } from "astro:transitions";
import SitePreference from "../components/site-preference.astro";
export interface Props {
  title: string;
  ogImageUrl?: string;
}
import Footer from "../components/footer.astro";

const { title, ogImageUrl } = Astro.props;
import { BLOG_TITLE } from "../constants";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="color-scheme" content="light dark" />
    <title>{title} - {BLOG_TITLE}</title>
    <script is:inline>
      {
        // Apply the persisted scheme before first paint to avoid a theme flash,
        // and re-apply it after ClientRouter swaps <html> on navigation
        const applyStoredColorScheme = () => {
          const stored = localStorage.getItem("preferred-color-scheme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.setAttribute("data-color-scheme", stored);
          }
        };
        applyStoredColorScheme();
        document.addEventListener("astro:after-swap", applyStoredColorScheme);
      }
    </script>
    <script
      async
      src="https://www.googletagmanager.com/gtag/js?id=UA-104175258-3"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "UA-104175258-3");
    </script>
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <ClientRouter />
  </head>
  <body>
    <nav class="global-nav" transition:name="global_nav">
      <div class="container global-nav-content">
        <a href="/" class="top-header-link">
          <img
            src="https://araya.dev/assets/icon.svg"
            alt="icon image"
            class="header-icon"
          />
          <p class="header-title">
            <span class="header-title-main">{BLOG_TITLE}</span>
          </p>
        </a>
        <SitePreference />
      </div>
    </nav>
    <div class="content">
      <slot />
    </div>
    <Footer />
    <style is:global>
      @import "../styles/main.css";
    </style>
    <style>
      .heading__lined {
        position: relative;
      }

      .heading__lined::before {
        content: "";
        display: flex;
        height: 100%;
        width: 5px;
        border-radius: 3px;
        position: absolute;
        top: 0;
        left: -24px;
        background: linear-gradient(
          180deg,
          var(--accent-gradient-from),
          var(--accent-gradient-to)
        );
      }

      .global-nav {
        height: var(--global-nav-height);
        background: var(--global-nav-bg);
        color: var(--color-text);
        /* リボンの一筋: ナビ下端のテーマ色グラデーションライン */
        border-bottom: 2px solid transparent;
        border-image: linear-gradient(
            90deg,
            var(--accent-gradient-from),
            var(--accent-gradient-to) 45%,
            transparent 90%
          )
          1;
      }

      .global-nav-content {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .content {
        padding-bottom: calc(var(--footer-height) + 80px);
      }

      .top-header-link {
        display: flex;
        align-items: center;
        padding: 1em;
        height: 100%;
      }

      .header-icon {
        height: 100%;
      }

      .header-title {
        display: inline-flex;
        height: 100%;
        align-items: flex-end;
        margin-left: 16px;
        font-family: var(--default-font-family);
        font-weight: 500;
      }
      .header-title-main {
        font-size: var(--font-size-xxl);
        line-height: 1;
      }
      .header-title-sub {
        margin-inline-start: 8px;
      }

      @media screen and (max-width: 767px) {
        .header-title {
          font-size: var(--font-size-md);
        }
      }
      .page-title {
        font-size: var(--font-size-xxxl);
      }
    </style>
  </body>
</html>
